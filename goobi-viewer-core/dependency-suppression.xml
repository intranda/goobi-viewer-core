    <!-- false positives -->

    <!-- CVE-2006-0197 is an X.Org vulnerability from 2006, incorrectly matched against jbibtex (a Java BibTeX parser) -->
    <suppress>
        <notes><![CDATA[
        file name: jbibtex-1.0.20.jar
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.jbibtex/jbibtex@.*$</packageUrl>
        <cve>CVE-2006-0197</cve>
    </suppress>

    <!-- CVE-2026-23907 only affects the ExtractEmbeddedFiles example program, not the PDFBox library itself -->

        <notes><![CDATA[
        file name: jetty-*.jar - transitive of solr-solrj, cannot be upgraded independently
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.eclipse\.jetty.*@.*$</packageUrl>
        <cve>CVE-2025-11143</cve>
    </suppress>



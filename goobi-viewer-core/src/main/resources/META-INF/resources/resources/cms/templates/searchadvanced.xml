    <label>cms_component__search_advanced__label</label>
    <description>cms_component__search_advanced__desc</description>
    <type>search</type>
    <content>
        <item id="heading">
            <label>heading</label>
            <className>io.goobi.viewer.model.cms.pages.content.types.CMSShortTextContent</className>
            <jsfComponent>
                <library>cms/components/backend/content</library>
                <name>text</name>
            </jsfComponent>
        </item>
        <item id="advancedsearch">
            <label>cms_component__search_advanced__label</label>
            <className>io.goobi.viewer.model.cms.pages.content.types.CMSAdvancedSearchContent</className>
            <jsfComponent>
                <library>cms/components/backend/content</library>
                <name>searchadvanced</name>

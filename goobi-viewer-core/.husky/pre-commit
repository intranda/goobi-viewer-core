#!/usr/bin/env sh
set -e
# Resolve module directory from this hook's path
SCRIPT_DIR="$(cd -- "$(dirname "$0")" >/dev/null 2>&1 && pwd)"
MODULE_DIR="$(cd -- "$SCRIPT_DIR/.." >/dev/null 2>&1 && pwd)"
REPO_ROOT="$(cd -- "$MODULE_DIR/.." >/dev/null 2>&1 && pwd)"

# Ensure module binaries (lint-staged, prettier) are on PATH
export PATH="$MODULE_DIR/node_modules/.bin:$PATH"

# Run lint-staged from the Git repo root, but use module's config and deps
cd "$REPO_ROOT"
npx --prefix "$MODULE_DIR" --no-install lint-staged --config "$MODULE_DIR/package.json"
